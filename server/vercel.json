{
  "rewrites": [{ "source": "/(.*)", "destination": "/api/index" }],
  "installCommand": "npm install",
  "buildCommand": "npm run build",
  "functions": {
    "api/index.ts": {
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/reminders/send-due",
      "schedule": "0 9 * * *"
    }
  ]
}
